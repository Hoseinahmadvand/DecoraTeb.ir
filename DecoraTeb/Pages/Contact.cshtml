@page
@model DecoraTeb.Pages.ContactModel
@{
}

<!-- ===== PAGE HEADER ===== -->
<section class="page-header blueprint-bg-dark">
    <div class="container">
        <nav class="page-crumb">
            <a href="dekoratebb.html">خانه</a> <span class="sep">/</span> <span>تماس با ما</span>
        </nav>
        <h1>بیایید درباره فضای مطب‌تان صحبت کنیم</h1>
        <p>چه در ابتدای راه ساخت مطب باشید و چه به دنبال بازسازی یک کلینیک قدیمی، تیم دکوراطب ظرف ۴۸ ساعت پاسخ‌گوی شماست.</p>
    </div>
    <div class="hs-shape"><svg viewBox="0 0 1440 70" preserveAspectRatio="none"><path d="M0,30 C280,80 500,0 760,22 C1040,46 1200,8 1440,38 L1440,70 L0,70 Z" fill="#fbf8f2"></path></svg></div>
</section>

<!-- ===== CONTACT INFO STRIP ===== -->
<section class="section-pad pb-0">
    <div class="container">
        <div class="row g-4 mb-5">
            <div class="col-md-4 reveal">
                <div class="service-card tilt-card h-100">
                    <div class="service-icon"><i class="bi bi-telephone"></i></div>
                    <h4>تماس تلفنی</h4>
                    <p class="mb-1">۰۲۱-۹۱۰۰۰۰۰۰</p>
                    <p class="mb-0">۰۹۱۲-۰۰۰۰۰۰۰</p>
                </div>
            </div>
            <div class="col-md-4 reveal">
                <div class="service-card tilt-card h-100">
                    <div class="service-icon"><i class="bi bi-envelope"></i></div>
                    <h4>ایمیل</h4>
                    <p class="mb-1">info@dekorateb.ir</p>
                    <p class="mb-0">projects@dekorateb.ir</p>
                </div>
            </div>
            <div class="col-md-4 reveal">
                <div class="service-card tilt-card h-100">
                    <div class="service-icon"><i class="bi bi-geo-alt"></i></div>
                    <h4>دفتر مرکزی</h4>
                    <p class="mb-0">تهران، خیابان ولیعصر، بالاتر از پارک ملت، ساختمان دکوراطب، طبقه ۳</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== FORM + MAP/HOURS ===== -->
<section class="section-pad bg-ivory">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-7 reveal">
                <span class="eyebrow d-inline-flex">فرم تماس</span>
                <h2 class="mt-3 mb-4">درخواست مشاوره رایگان</h2>
                <form class="row g-3 bg-white p-4 p-md-5 rounded-4 shadow-sm" id="contactForm" novalidate>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">نام و نام خانوادگی</label>
                        <input type="text" class="form-control form-control-custom" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">شماره تماس</label>
                        <input type="tel" class="form-control form-control-custom" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">شهر</label>
                        <input type="text" class="form-control form-control-custom">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">نوع فضای درمانی</label>
                        <select class="form-select form-control-custom">
                            <option>مطب دندانپزشکی</option>
                            <option>کلینیک پوست و زیبایی</option>
                            <option>مطب عمومی و تخصصی</option>
                            <option>سایر</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">توضیحات پروژه</label>
                        <textarea class="form-control form-control-custom" rows="4" placeholder="متراژ، بودجه تقریبی، و توضیح کوتاهی از نیازتان..."></textarea>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-copper w-100 py-3">ارسال درخواست مشاوره</button>
                    </div>
                    <div class="col-12 text-center small text-success d-none" id="formSuccess">
                        <i class="bi bi-check-circle-fill me-1"></i> درخواست شما ثبت شد؛ به‌زودی با شما تماس می‌گیریم.
                    </div>
                </form>
            </div>
            <div class="col-lg-5 reveal">
                <span class="eyebrow d-inline-flex">موقعیت ما</span>
                <h2 class="mt-3 mb-4">دفتر مرکزی دکوراطب</h2>
                <div class="map-placeholder mb-4">
                    <div class="map-pin"></div>
                    <i class="bi bi-geo-alt-fill pin-icon"></i>
                    <span>نقشه دفتر دکوراطب — تهران، خیابان ولیعصر</span>
                </div>
                <div class="bg-white rounded-4 p-4 border">
                    <h6 class="fw-bold mb-3"><i class="bi bi-clock text-forest me-2"></i> ساعات پاسخ‌گویی</h6>
                    <div class="hours-row"><span>شنبه تا چهارشنبه</span><span class="fw-bold">۹:۰۰ – ۱۸:۰۰</span></div>
                    <div class="hours-row"><span>پنجشنبه</span><span class="fw-bold">۹:۰۰ – ۱۳:۰۰</span></div>
                    <div class="hours-row"><span>جمعه</span><span class="fw-bold text-secondary">تعطیل</span></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== FAQ ===== -->
<section class="section-pad">
    <div class="container">
        <div class="row gy-5">
            <div class="col-lg-4 reveal">
                <span class="eyebrow mb-3 d-inline-flex">سوالات پرتکرار</span>
                <h2>قبل از تماس، شاید جواب اینجا باشد</h2>
                <p class="text-secondary mt-3">اگر پاسخ سوال خود را پیدا نکردید، خوشحال می‌شویم مستقیم با ما تماس بگیرید.</p>
            </div>
            <div class="col-lg-8 reveal">
                <div class="accordion accordion-custom" id="faqAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                هزینه مشاوره اولیه و بازدید چقدر است؟
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">بازدید اولیه و مشاوره ابتدایی برای همه متقاضیان کاملاً رایگان است و هیچ تعهدی برای ادامه همکاری ایجاد نمی‌کند.</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                اجرای پروژه چقدر طول می‌کشد؟
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">بسته به متراژ و میزان تغییرات، معمولاً بین ۳ تا ۸ هفته زمان می‌برد. زمان دقیق پس از بازدید و طراحی نهایی مشخص می‌شود.</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                آیا در طول اجرا مطب باید تعطیل شود؟
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">در بیشتر پروژه‌ها با زمان‌بندی مرحله‌ای، نیازی به تعطیلی کامل نیست. این موضوع در جلسه اول با شما هماهنگ می‌شود.</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                آیا در شهرستان‌ها هم فعالیت می‌کنید؟
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">بله، تیم دکوراطب تاکنون در ۱۲ شهر کشور پروژه اجرا کرده و آماده همکاری در سایر شهرها نیز هست.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>