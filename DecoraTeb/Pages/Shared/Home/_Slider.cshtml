@using DecoraTeb.ViewModels.Slider
@model List<SliderVm>


<section class="hero-slider" id="home">

    <div class="hs-track" id="heroSlider">

        @for (int i = 0; i < Model.Count; i++)
        {
            var item = Model[i];

            <div class="hs-slide @(i == 0 ? "active" : "")" data-slide="@i">

                <div class="hs-media">

                    @if (!string.IsNullOrWhiteSpace(item.Image))
                    {
                        <img class="hs-img"
                             src="/uploads/slider/@item.Image"
                             alt="@item.Title" />
                    }
                    else
                    {
                        <div class="hs-placeholder">
                            <i class="bi bi-image"></i>
                            <span>تصویری ثبت نشده است</span>
                        </div>
                    }

                </div>

                <div class="container hs-content">

                    <div>

                        <div class="hs-num">

                            @($"{i + 1:00}") / @($"{Model.Count:00}")

                            @if (!string.IsNullOrWhiteSpace(item.SubTitle))
                            {
                                <span> — @item.SubTitle</span>
                            }

                        </div>

                        <span class="hs-tagpill">

                            @item.SubTitle

                        </span>

                        <h1>

                            @item.Title

                        </h1>

                        <p>

                            @item.Description

                        </p>

                        <div class="d-flex flex-wrap gap-3">

                            @if (!string.IsNullOrWhiteSpace(item.ButtonLink))
                            {
                                <a href="@item.ButtonLink"
                                   class="btn btn-copper">

                                    @(string.IsNullOrWhiteSpace(item.ButtonText)
                                        ? "مشاهده بیشتر"
                                        : item.ButtonText)

                                    <i class="bi bi-arrow-left ms-1"></i>

                                </a>
                            }

                            <a href="#projects"
                               class="btn btn-outline-ivory">

                                مشاهده نمونه‌کارها

                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

        <!-- side vertical indicators -->

        <div class="hs-indicators">

            @for (int i = 0; i < Model.Count; i++)
            {
                <button class="hs-dash @(i==0?"active":"")"
                        data-goto="@i">
                </button>
            }

        </div>

        <!-- arrows -->

        <div class="hs-arrows">

            <button class="hs-arrow" id="hsPrev">

                <i class="bi bi-arrow-right"></i>

            </button>

            <button class="hs-arrow" id="hsNext">

                <i class="bi bi-arrow-left"></i>

            </button>

        </div>

        <!-- counter -->

        <div class="hs-counter">

            <b id="hsCurrent">۰۱</b> / @Model.Count.ToString("00")

        </div>

        <!-- organic bottom shape -->

        <div class="hs-shape">

            <svg viewBox="0 0 1440 90" preserveAspectRatio="none">

                <path d="M0,40 C280,110 500,0 760,30 C1040,62 1200,10 1440,50 L1440,90 L0,90 Z"
                      fill="#fbf8f2">
                </path>

            </svg>

        </div>

    </div>

</section>
