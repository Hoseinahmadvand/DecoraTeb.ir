@model List<DecoraTeb.ViewModels.Blog.BlogListItemVm>


<section class="section-pad" id="blog">

    <div class="container">

        <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3 reveal">

            <div>

                <span class="eyebrow d-inline-flex">

                    بلاگ دکوراطب

                </span>

                <h2 class="mt-3 mb-0">

                    راهنمای طراحی فضای درمانی

                </h2>

            </div>

            <a asp-page="/Blogs/Index"
               class="btn btn-outline-forest">

                مشاهده همه مقالات

            </a>

        </div>

        <div class="swipe-hint">

            <i class="bi bi-hand-index-thumb"></i>

            برای مطالعه مقالات بیشتر، بکشید

        </div>

        <div class="row g-4 mobile-slider">

            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 reveal">

                    <article class="blog-card">

                        <a asp-page="/Blogs/Details"
                           asp-route-slug="@item.Slug"
                           class="text-decoration-none">

                            <div class="blog-thumb">

                                @if (!string.IsNullOrWhiteSpace(item.Image))
                                {
                                    <img src="/uploads/blogs/@item.Image"
                                         alt="@item.Title">
                                }

                                <span class="blog-cat">

                                    @item.BlogCategoryId

                                </span>

                            </div>

                            <div class="blog-body">

                                <div class="blog-meta mb-2">

                                    <i class="bi bi-calendar3 me-1"></i>

                                    @item.PublishDate

                                </div>

                                <h5>

                                    @item.Title

                                </h5>

                                <p>

                                    @item.Summary

                                </p>

                                <span class="text-forest fw-bold">

                                    ادامه مطلب

                                    <i class="bi bi-arrow-left"></i>

                                </span>

                            </div>

                        </a>

                    </article>

                </div>
            }

        </div>

    </div>

</section>







