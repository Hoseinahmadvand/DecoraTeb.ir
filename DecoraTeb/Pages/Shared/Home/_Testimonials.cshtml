@model List<DecoraTeb.ViewModels.Testimonial.TestimonialVm>
<section class="section-pad bg-forest blueprint-bg-dark">

    <div class="container">

        <div class="text-center mb-5 reveal">

            <span class="eyebrow justify-content-center d-inline-flex">
                نظر مشتریان
            </span>

            <h2 class="mt-3">
                حرف کسانی که با ما ساختند
            </h2>

        </div>

        <div id="testiCarousel"
             class="carousel slide reveal"
             data-bs-ride="carousel">

            <div class="carousel-inner">

                @for (int i = 0; i < Model.Count; i++)
                {
                    var item = Model[i];

                    <div class="carousel-item @(i==0 ? "active" : "")">

                        <div class="testi-card">

                            @if (!string.IsNullOrWhiteSpace(item.Image))
                            {
                                <img class="testi-avatar-img"
                                     src="/uploads/testimonial/@item.Image"
                                     alt="@item.FullName">
                            }
                            else
                            {
                                <div class="testi-avatar">

                                    @(item.FullName.Length >= 2
                                        ? item.FullName.Substring(0, 2)
                                        : item.FullName)

                                </div>
                            }

                            <div class="mb-3">

                                @for (int j = 1; j <= 5; j++)
                                {
                                    if (j <= item.Rate)
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-warning"></i>
                                    }
                                }

                            </div>

                            <p class="testi-quote">

                                "@item.Comment"

                            </p>

                            <div class="fw-bold mt-3">

                                @item.FullName

                            </div>

                            <div class="small text-secondary">

                                @item.JobTitle

                            </div>

                        </div>

                    </div>
                }

            </div>

            @if (Model.Count > 1)
            {
                <div class="carousel-indicators position-relative mt-4"
                     style="bottom:0;">

                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <button type="button"
                                data-bs-target="#testiCarousel"
                                data-bs-slide-to="@i"
                                class="@(i==0 ? "active" : "")">
                        </button>
                    }

                </div>
            }

        </div>

    </div>

</section>
