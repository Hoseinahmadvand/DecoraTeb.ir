@model List<DecoraTeb.ViewModels.Service.ServiceVm>

<section class="section-pad bg-ivory blueprint-bg" id="services">

    <div class="container">

        <div class="text-center mb-5 reveal">
            <span class="eyebrow justify-content-center d-inline-flex">
                خدمات ما
            </span>

            <h2 class="mt-3">
                هر تخصص، چیدمان و نور خودش را می‌خواهد
            </h2>

            <p class="text-secondary mx-auto" style="max-width:600px;">
                از دندانپزشکی تا پوست و زیبایی، هر رشته پزشکی نیازهای فضایی متفاوتی دارد.
            </p>
        </div>

        <div class="row g-4">

            @foreach (var item in Model.OrderBy(x => x.SortOrder))
            {
                <div class="col-lg-4 col-md-6 reveal">

                    <a asp-page="/Services/Details"
                       asp-route-slug="@item.Slug"
                       class="text-decoration-none">

                        <div class="service-card h-100">

                           

                            <div class="service-body">

                                <div class="d-flex align-items-center justify-content-between mb-3">

                                    @* <div class="service-icon">

                                        <i class="@item.Icon"></i>

                                    </div> *@

                                    <div class="service-num">

                                        @item.SortOrder.ToString("00")

                                    </div>

                                </div>

                                <h4>

                                    @item.Title

                                </h4>

                                <p>

                                    @item.ShortDescription

                                </p>

                            </div>

                        </div>

                    </a>

                </div>
            }

        </div>

    </div>

</section>




