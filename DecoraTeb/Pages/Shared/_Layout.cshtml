<!DOCTYPE html>

<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>دکوراطب | @ViewData["Title"] </title>
    <meta name="description" content="دکوراطب؛ طراحی و اجرای داخلی مطب، کلینیک و مراکز درمانی با ترکیب آرامش بصری و استانداردهای پزشکی">
    <link rel="icon" type="image/png" href="~/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="~/css/style.css" rel="stylesheet" />
</head>
<body>
    <!-- ===== NAVBAR ===== -->
    <nav class="navbar navbar-expand-lg navbar-custom" id="mainNav">
        <div class="container">
            <a class="navbar-brand nav-brand" href="#home">
                <span class="brand-mark">DT</span>
                دکوراطب
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <i class="bi bi-list fs-2"></i>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto gap-1 py-3 py-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-page="Index">خانه</a></li>
                    <li class="nav-item"><a class="nav-link" href="./AboutUs">درباره ما</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="./Services">خدمات</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="./Projects">پروژه‌ها</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="./blogs">بلاگ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="./Contact">تماس با ما</a></li>
                </ul>
                <a href="#contact" class="btn btn-copper d-none d-lg-inline-block">مشاوره رایگان</a>
            </div>
        </div>
    </nav>


    @RenderBody()

    <!-- ===== FOOTER ===== -->
    <footer>
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <a class="nav-brand mb-3 d-flex" href="#home" style="color:var(--ivory)!important;">
                        <span class="brand-mark">DT</span> دکوراطب
                    </a>
                    <p class="small">استودیو تخصصی طراحی و اجرای داخلی مطب، کلینیک و مراکز درمانی در سراسر ایران.</p>
                </div>
                <div class="col-lg-2 col-6">
                    <h6>دسترسی سریع</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2 small">
                        <li><a href="#about">درباره ما</a></li>
                        <li><a href="#services">خدمات</a></li>
                        <li><a href="#projects">پروژه‌ها</a></li>
                        <li><a href="#blog">بلاگ</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-6">
                    <h6>خدمات</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2 small">
                        <li><a href="#services">طراحی مطب دندانپزشکی</a></li>
                        <li><a href="#services">کلینیک پوست و زیبایی</a></li>
                        <li><a href="#services">نورپردازی درمانی</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6>ما را دنبال کنید</h6>
                    <div class="d-flex gap-2 mb-3">
                        <a href="#" class="footer-social"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="footer-social"><i class="bi bi-telegram"></i></a>
                        <a href="#" class="footer-social"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>
            <hr class="my-4" style="border-color:rgba(247,242,233,0.15);">
            <div class="d-flex flex-wrap justify-content-between small">
                <span>© ۱۴۰۴ دکوراطب. تمامی حقوق محفوظ است.</span>
                <span>طراحی‌شده با <i class="bi bi-heart-fill text-copper"></i> برای فضاهای درمانی</span>
            </div>
        </div>
    </footer>

    <button id="backTop"><i class="bi bi-arrow-up"></i></button>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/script.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>