@page
@model IndexModel
@{
    ViewData["Title"] = "صفحه اصلی ";
}
<!-- ===== HERO SLIDER BANNER ===== -->
<partial name="./Shared/Home/_Slider"
         model="Model.Home.Sliders" />

<!-- floating stats overlapping the wave -->
<div class="container hero-stats-float">
    <div class="hero-stats-card">
        <div class="row g-3 text-center align-items-center">
            <div class="col-4 col-md-3"><div class="stat-num" data-count="180">0</div><div class="stat-label">مطب و کلینیک طراحی‌شده</div></div>
            <div class="col-4 col-md-3 border-start border-end"><div class="stat-num" data-count="9">0</div><div class="stat-label">سال تجربه اجرایی</div></div>
            <div class="col-4 col-md-3"><div class="stat-num" data-count="98">0</div><div class="stat-label">درصد رضایت کارفرما</div></div>
            <div class="col-12 col-md-3 mt-3 mt-md-0">
                <a href="#contact" class="btn btn-outline-forest w-100">شروع پروژه من <i class="bi bi-arrow-left ms-1"></i></a>
            </div>
        </div>
    </div>
</div>

<!-- ===== ABOUT ===== -->
<section class="section-pad" id="about">
    <div class="container">
        <div class="row align-items-center gy-5">
            <div class="col-lg-5 reveal">
                <span class="eyebrow mb-3 d-inline-flex">درباره دکوراطب</span>
                <h2 class="mb-4">طراحی داخلی، وقتی به زبان پزشکی مسلط باشد</h2>
                <p class="text-secondary" style="line-height:2;">تیم دکوراطب از معماران داخلی و کارشناسانی تشکیل شده که سال‌ها فقط روی فضاهای درمانی کار کرده‌اند؛ از مطب تک‌نفره تا کلینیک چندتخصصی. ما می‌دانیم مسیر حرکت بیمار، نور اتاق معاینه، جنس کفپوش ضدعفونی‌پذیر و صدای محیط، به همان اندازه زیبایی بصری اهمیت دارد.</p>
                <div class="row g-3 mt-2">
                    <div class="col-sm-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-shield-check fs-4 text-forest"></i>
                            <div><strong>استاندارد بهداشتی</strong><div class="small text-secondary">مطابق ضوابط نظام پزشکی</div></div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-rulers fs-4 text-forest"></i>
                            <div><strong>ارگونومی کامل</strong><div class="small text-secondary">برای بیمار و کادر درمان</div></div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-palette fs-4 text-forest"></i>
                            <div><strong>هویت بصری برند</strong><div class="small text-secondary">هماهنگ با تخصص شما</div></div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-clock-history fs-4 text-forest"></i>
                            <div><strong>اجرای زمان‌بندی‌شده</strong><div class="small text-secondary">بدون توقف فعالیت مطب</div></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7 reveal">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 bg-ivory h-100">
                            <i class="bi bi-quote fs-2 text-copper"></i>
                            <p class="mt-3" style="line-height:1.9;">«هدف ما کاهش اضطراب بیمار از لحظه ورود است؛ نور، رنگ و چیدمان می‌توانند بخشی از فرآیند درمان باشند.»</p>
                            <div class="fw-bold mt-3">تیم طراحی دکوراطب</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 h-100 text-white" style="background:var(--forest);">
                            <div class="fs-1 fw-bold">+٩</div>
                            <div class="mb-3">سال همکاری با پزشکان و مدیران کلینیک در سراسر کشور</div>
                            <div class="divider-gold"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="p-4 rounded-4 border h-100 d-flex flex-wrap gap-4 align-items-center justify-content-between">
                            <div><i class="bi bi-award fs-3 text-forest"></i><div class="small fw-bold mt-2">طراحی برتر ۱۴۰۲</div></div>
                            <div><i class="bi bi-people fs-3 text-forest"></i><div class="small fw-bold mt-2">+۴۰ متخصص همکار</div></div>
                            <div><i class="bi bi-building fs-3 text-forest"></i><div class="small fw-bold mt-2">۱۲ شهر فعالیت</div></div>
                            <div><i class="bi bi-hand-thumbs-up fs-3 text-forest"></i><div class="small fw-bold mt-2">ضمانت اجرا</div></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== SERVICES ===== -->
<partial name="./Shared/Home/_Services"
         model="Model.Home.Services" />



<!-- ===== PROCESS ===== -->
<section class="section-pad" id="process">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <span class="eyebrow justify-content-center d-inline-flex">مسیر همکاری</span>
            <h2 class="mt-3">از بازدید اول تا تحویل کلید</h2>
        </div>
        <div class="row process-line g-4">
            <div class="col-6 col-md-3 process-step reveal">
                <div class="process-badge">۱</div>
                <h5>مشاوره و بازدید</h5>
                <p>بررسی متراژ، تخصص و بودجه در محل مطب شما</p>
            </div>
            <div class="col-6 col-md-3 process-step reveal">
                <div class="process-badge">۲</div>
                <h5>طراحی و مدل‌سازی</h5>
                <p>ارائه نقشه، رندر سه‌بعدی و لیست متریال</p>
            </div>
            <div class="col-6 col-md-3 process-step reveal">
                <div class="process-badge">۳</div>
                <h5>اجرای پروژه</h5>
                <p>نظارت مهندسی روزانه با زمان‌بندی مشخص</p>
            </div>
            <div class="col-6 col-md-3 process-step reveal">
                <div class="process-badge">۴</div>
                <h5>تحویل و پشتیبانی</h5>
                <p>تحویل نهایی و پشتیبانی فنی تا یک سال</p>
            </div>
        </div>
    </div>
</section>



<!-- ===== PROJECTS ===== -->
<partial name="./Shared/Home/_Projects"
         model="Model.Home.Projects" />



<!-- ===== TESTIMONIALS ===== -->

<partial name="./Shared/Home/_Testimonials"
         model="Model.Home.Testimonials" />



<!-- ===== BLOG ===== -->
<partial name="./Shared/Home/_Blogs"
         model="Model.Home.LatestBlogs" />



<!-- ===== CTA BAND ===== -->
<section class="pb-5">
    <div class="container">
        <div class="cta-band reveal">
            <div class="row align-items-center position-relative">
                <div class="col-lg-8">
                    <h2 class="mb-2">آماده‌اید فضای مطب‌تان را متحول کنید؟</h2>
                    <p class="mb-0 opacity-75">همین امروز وقت بازدید رایگان بگیرید؛ تیم ما ظرف ۴۸ ساعت با شما تماس می‌گیرد.</p>
                </div>
                <div class="col-lg-4 text-lg-start mt-4 mt-lg-0">
                    <a href="#contact" class="btn btn-copper w-100">رزرو وقت مشاوره</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== CONTACT ===== -->
<section class="section-pad bg-ivory" id="contact">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5 reveal">
                <span class="eyebrow d-inline-flex">تماس با ما</span>
                <h2 class="mt-3 mb-4">گفت‌وگو را شروع کنیم</h2>
                <p class="text-secondary mb-4">برای دریافت مشاوره رایگان یا بازدید حضوری از فضای مطب، فرم روبه‌رو را پر کنید یا مستقیم تماس بگیرید.</p>
                <div class="contact-info-item">
                    <div class="contact-icon"><i class="bi bi-telephone"></i></div>
                    <div><strong>تماس تلفنی</strong><div class="text-secondary small">۰۲۱-۹۱۰۰۰۰۰۰</div></div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-icon"><i class="bi bi-envelope"></i></div>
                    <div><strong>ایمیل</strong><div class="text-secondary small">info@dekorateb.ir</div></div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-icon"><i class="bi bi-geo-alt"></i></div>
                    <div><strong>دفتر مرکزی</strong><div class="text-secondary small">تهران، خیابان ولیعصر، ساختمان دکوراطب</div></div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <a href="#" class="footer-social" style="border-color:var(--line);color:var(--forest);"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="footer-social" style="border-color:var(--line);color:var(--forest);"><i class="bi bi-telegram"></i></a>
                    <a href="#" class="footer-social" style="border-color:var(--line);color:var(--forest);"><i class="bi bi-whatsapp"></i></a>
                </div>
            </div>
            <div class="col-lg-7 reveal">
                <form class="row g-3 bg-white p-4 p-md-5 rounded-4 shadow-sm" id="contactForm" novalidate>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">نام و نام خانوادگی</label>
                        <input type="text" class="form-control form-control-custom" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">شماره تماس</label>
                        <input type="tel" class="form-control form-control-custom" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">نوع فضای درمانی</label>
                        <select class="form-select form-control-custom">
                            <option>مطب دندانپزشکی</option>
                            <option>کلینیک پوست و زیبایی</option>
                            <option>مطب عمومی و تخصصی</option>
                            <option>سایر</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">توضیحات پروژه</label>
                        <textarea class="form-control form-control-custom" rows="4" placeholder="متراژ، شهر، و توضیح کوتاهی از نیازتان..."></textarea>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-copper w-100 py-3">ارسال درخواست مشاوره</button>
                    </div>
                    <div class="col-12 text-center small text-success d-none" id="formSuccess">
                        <i class="bi bi-check-circle-fill me-1"></i> درخواست شما ثبت شد؛ به‌زودی با شما تماس می‌گیریم.
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
