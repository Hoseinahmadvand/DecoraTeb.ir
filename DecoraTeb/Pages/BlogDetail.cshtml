@page "{slug}"
@using DecoraTeb.Extensions
@model DecoraTeb.Pages.BlogDetailModel


@{
    ViewData["Title"] = Model.Blog.Title;
}

<!-- ===== PAGE HEADER ===== -->
<section class="page-header blueprint-bg-dark">
    <div class="container">

        <nav class="page-crumb">
            <a asp-page="/Index">خانه</a>
            <span class="sep">/</span>
            <a asp-page="/Blogs">بلاگ</a>
            <span class="sep">/</span>
            <span>@Model.Blog.Title</span>
        </nav>

        <h1 class="detail-title-lg">@Model.Blog.Title</h1>

        <p>@Model.Blog.Summary</p>

        <div class="mt-3">

            <span class="meta-chip">
                <i class="bi bi-person"></i>
                @Model.Blog.Author
            </span>

            <span class="meta-chip">
                <i class="bi bi-calendar3"></i>
                @Model.Blog.CreateDate.ToShamsi()
            </span>

            <span class="meta-chip">
                <i class="bi bi-clock"></i>
                @Model.Blog.ReadingTime دقیقه مطالعه
            </span>

            <span class="meta-chip">
                <i class="bi bi-tag"></i>
                @Model.Blog.Category
            </span>

        </div>

    </div>

    <div class="hs-shape">
        <svg viewBox="0 0 1440 70" preserveAspectRatio="none">
            <path d="M0,30 C280,80 500,0 760,22 C1040,46 1200,8 1440,38 L1440,70 L0,70 Z"
                  fill="#fbf8f2"></path>
        </svg>
    </div>

</section>

<!-- تصویر شاخص -->
<div class="container featured-media">

    <div class="media-inner">

        <img src="/uploads/blogs/@Model.Blog.Image"
             alt="@Model.Blog.Title"
             class="img-fluid rounded-4 w-100" />

    </div>

</div>

<!-- ===== CONTENT ===== -->

<section class="section-pad">

    <div class="container">

        <div class="row g-5">

            <!-- مقاله -->

            <div class="col-lg-8">

                <div class="article-body">

                    @Html.Raw(Model.Blog.Description)

                </div>

            </div>

            <!-- سایدبار -->

            <div class="col-lg-4">

                <div class="author-box mb-4">

                    <div class="team-avatar">
                        @(Model.Blog.Author?.Substring(0,1))
                    </div>

                    <div>

                        <h6 class="fw-bold mb-1">
                            @Model.Blog.Author
                        </h6>

                        <div class="small text-secondary">
                            نویسنده دکوراطب
                        </div>

                    </div>

                </div>

                <div class="sidebar-card mb-4">

                    <h6 class="fw-bold mb-3">
                        اشتراک گذاری
                    </h6>

                    <div class="share-row">

                        <a href="#" class="share-btn">
                            <i class="bi bi-instagram"></i>
                        </a>

                        <a href="#" class="share-btn">
                            <i class="bi bi-telegram"></i>
                        </a>

                        <a href="#" class="share-btn">
                            <i class="bi bi-whatsapp"></i>
                        </a>

                    </div>

                </div>

                <div class="sidebar-card">

                    <h6 class="fw-bold mb-3">
                        مقالات محبوب
                    </h6>

                    @foreach (var item in Model.Blog.RelatedBlogs.Take(3))
                    {
                        <a asp-page="/BlogDetail"
                           asp-route-slug="@item.Slug"
                           class="popular-post">

                            <div class="popular-thumb">

                                <img src="/uploads/blog/@item.Image"
                                     class="img-fluid rounded"
                                     alt="@item.Title">

                            </div>

                            <div>

                                <div class="popular-post-title">

                                    @item.Title

                                </div>

                                <div class="popular-post-date">

                                    @item.PublishDate.ToShamsi()

                                </div>

                            </div>

                        </a>
                    }

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ===== RELATED ===== -->

<section class="section-pad bg-ivory blueprint-bg">

    <div class="container">

        <div class="text-center mb-5">

            <span class="eyebrow">
                مقالات مرتبط
            </span>

            <h2 class="mt-3">
                ادامه مطالعه
            </h2>

        </div>

        <div class="row g-4">

            @foreach (var item in Model.Blog.RelatedBlogs)
            {
                <div class="col-lg-4 col-md-6">

                    <a asp-page="/BlogDetail"
                       asp-route-slug="@item.Slug"
                       class="text-decoration-none text-reset">

                        <div class="blog-card">

                            <div class="blog-thumb">

                                <img src="/uploads/blog/@item.Image"
                                     class="img-fluid"
                                     alt="@item.Title">

                                <span class="blog-cat">

                                    @item.CategoryName

                                </span>

                            </div>

                            <div class="blog-body">

                                <div class="blog-meta mb-2">

                                    <i class="bi bi-calendar3"></i>

                                    @item.PublishDate.ToShamsi()

                                </div>

                                <h5>

                                    @item.Title

                                </h5>

                                <p>

                                    @item.Summary

                                </p>

                            </div>

                        </div>

                    </a>

                </div>
            }

        </div>

    </div>

</section>