@page
@model DecoraTeb.Pages.ProjectsModel
@{
}

<!-- ===== PAGE HEADER ===== -->

<section class="page-header blueprint-bg-dark">

    <div class="container">

        <nav class="page-crumb">

            <a asp-page="/Index">خانه</a>

            <span class="sep">/</span>

            <span>پروژه ها</span>

        </nav>

        <h1>
            نمونه‌کارهایی که با دقت پزشکی طراحی شده‌اند
        </h1>

        <p>
            مجموعه‌ای از مطب‌ها و کلینیک‌هایی که از صفر تا تحویل کلید،
            توسط تیم دکوراطب طراحی و اجرا شده‌اند.
        </p>

    </div>

    <div class="hs-shape">
        <svg viewBox="0 0 1440 70" preserveAspectRatio="none">
            <path d="M0,30 C280,80 500,0 760,22 C1040,46 1200,8 1440,38 L1440,70 L0,70 Z"
                  fill="#fbf8f2">
            </path>
        </svg>
    </div>

</section>

<!-- ===== PROJECTS ===== -->

<section class="section-pad">

    <div class="container">

        <div class="d-flex justify-content-center filter-pills mb-5 flex-wrap">

            <button class="btn active"
                    data-filter="all">

                همه پروژه‌ها

            </button>

            @foreach (var item in Model.Projects.Categories)
            {
                <button class="btn"
                        data-filter="@item.Slug">

                    @item.Title

                </button>
            }

        </div>

        <div class="row g-4" id="projectGrid">

            @foreach (var item in Model.Projects.Projects)
            {
                <div class="col-lg-4 col-md-6 project-item reveal"
                     data-cat="@item.CategoryTitle">

                    <a asp-page="/ProjectDetail"
                       asp-route-slug="@item.Slug"
                       class="text-decoration-none">

                        <div class="project-card">

                            <div class="project-visual">

                                @if (!string.IsNullOrWhiteSpace(item.CoverImage))
                                {
                                    <img src="/uploads/projects/@item.CoverImage"
                                         alt="@item.Title"
                                         class="img-fluid w-100 h-100 object-fit-cover" />
                                }
                                else
                                {
                                    <div class="project-placeholder">

                                        <i class="bi bi-image"></i>

                                    </div>
                                }

                            </div>

                            <div class="project-overlay">

                                <span class="project-tag">

                                    @item.CategoryTitle

                                </span>

                                <h5 class="mb-2">

                                    @item.Title

                                </h5>

                                <div class="small opacity-75 mb-2">

                                    <i class="bi bi-geo-alt"></i>

                                    @item.Location

                                </div>

                                @if (item.Area > 0)
                                {
                                    <div class="small opacity-75">

                                        <i class="bi bi-rulers"></i>

                                        @item.Area متر مربع

                                    </div>
                                }

                            </div>

                        </div>

                    </a>

                </div>
            }

        </div>

        @if (Model.Projects.Projects.Count >= 9)
        {
            <div class="text-center mt-5">

                <button class="btn btn-loadmore"
                        id="loadMoreBtn">

                    مشاهده پروژه‌های بیشتر

                    <i class="bi bi-arrow-down ms-1"></i>

                </button>

            </div>
        }

    </div>

</section>

<!-- ===== CTA ===== -->

<section class="pb-5">

    <div class="container">

        <div class="cta-band reveal">

            <div class="row align-items-center position-relative">

                <div class="col-lg-8">

                    <h2 class="mb-2">

                        پروژه بعدی، مطب شماست

                    </h2>

                    <p class="mb-0 opacity-75">

                        همین امروز وقت بازدید رایگان بگیرید و مسیر تبدیل فضای‌تان را شروع کنید.

                    </p>

                </div>

                <div class="col-lg-4 text-lg-start mt-4 mt-lg-0">

                    <a asp-page="/Contact"
                       class="btn btn-copper w-100">

                        رزرو وقت مشاوره

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>
