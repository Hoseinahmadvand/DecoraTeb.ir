@page
@model DecoraTeb.Areas.Admin.Pages.WebPage.IndexModel

@{
    ViewData["Title"] = "مدیریت صفحات";
}

<div class="card">

    <div class="card-header">

        <h3 class="card-title">
            مدیریت صفحات سایت
        </h3>

    </div>

    <div class="card-body table-responsive">

        <table class="table table-bordered table-hover text-center">

            <thead>

                <tr>

                    <th>#</th>

                    <th>عنوان</th>

                    <th>نوع صفحه</th>

                    <th>ترتیب</th>

                    <th>وضعیت</th>

                    <th>عملیات</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.Pages)
                {
                    <tr>

                        <td>@item.Id</td>

                        <td>@item.Title</td>

                        <td>@item.Type</td>

                        <td>@item.SortOrder</td>

                        <td>

                            @if (item.IsActive)
                            {
                                <span class="badge badge-success">
                                    فعال
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-danger">
                                    غیرفعال
                                </span>
                            }

                        </td>

                        <td>

                            <a asp-page="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">

                                <i class="fa fa-edit"></i>

                            </a>

                            <form method="post"
                                  asp-page-handler="ChangeStatus"
                                  style="display:inline">

                                <input type="hidden"
                                       name="id"
                                       value="@item.Id" />

                                <button class="btn btn-info btn-sm">

                                    <i class="fa fa-refresh"></i>

                                </button>

                            </form>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>