@page "{id:long}"

@model DecoraTeb.Areas.Admin.Pages.Project.EditModel


@{
    ViewData["Title"] = "ویرایش پروژه";
}

<div class="card">

    <div class="card-header">

        <h4>ویرایش پروژه</h4>

    </div>

    <div class="card-body">

        <form method="post"
              enctype="multipart/form-data">

            <partial name="_ProjectForm"
                     model="Model.Project" />

        </form>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}