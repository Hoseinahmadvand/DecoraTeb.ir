@page
@model DecoraTeb.Areas.Admin.Pages.Project.IndexModel
@{
    ViewData["Title"] = "مدیریت پروژه ها";
}
<div class="d-flex justify-content-between align-items-center mb-4">

    <h3>مدیریت پروژه ها</h3>

    <a asp-page="Create"
       class="btn btn-success">

        <i class="bi bi-plus-lg"></i>

        پروژه جدید

    </a>

</div>
<form method="get">

    <div class="row">

        <div class="col-md-4">

            <input asp-for="Filter.Title"
                   class="form-control"
                   placeholder="جستجو..." />

        </div>

        <div class="col-md-3">

            <button class="btn btn-primary">

                جستجو

            </button>

        </div>

    </div>

</form>

<hr />


<table class="table table-hover align-middle">

    <thead>

        <tr>

            <th>تصویر</th>

            <th>عنوان</th>

            <th>دسته بندی</th>

            <th>سال اجرا</th>

            <th>ویژه</th>

            <th>ترتیب</th>

            <th></th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model.Project)
        {
            <tr>

                <td width="100">

                    <img src="~/uploads/projects/@item.CoverImage"
                         width="90"
                         class="rounded" />

                </td>

                <td>

                    @item.Title

                </td>

                <td>

                    @item.CategoryTitle

                </td>

                <td>

                    @item.ExecutionYear

                </td>

                <td>

                    @if (item.IsFeatured)
                    {
                        <span class="badge bg-success">

                            بله

                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">

                            خیر

                        </span>
                    }

                </td>

                <td>

                    @item.SortOrder

                </td>

                <td>

                    <a asp-page="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">

                        ویرایش

                    </a>

                    <form method="post"
                          asp-page-handler="Delete"
                          asp-route-id="@item.Id"
                          class="d-inline">

                        <button class="btn btn-danger btn-sm"
                                onclick="return confirm('حذف شود؟')">

                            حذف

                        </button>

                    </form>

                </td>

            </tr>
        }

    </tbody>

</table>
