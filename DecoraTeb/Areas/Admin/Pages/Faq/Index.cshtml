@page
@model DecoraTeb.Areas.Admin.Pages.Faq.IndexModel


@{
    ViewData["Title"] = "مدیریت سوالات متداول";
}

<div class="card col-12">

    <div class="card-header d-flex justify-content-between align-items-center">

        <h5>مدیریت سوالات متداول</h5>

        <button class="btn btn-success"
                data-bs-toggle="modal"
                data-bs-target="#createModal">

            <i class="bi bi-plus"></i>

            افزودن سوال

        </button>

    </div>

    <div class="card-body">

        <table class="table table-bordered table-hover align-middle">

            <thead>

                <tr>

                    <th>#</th>

                    <th>سوال</th>

                    <th>ترتیب</th>

                    <th>وضعیت</th>

                    <th width="180">عملیات</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.Faqs)
                {
                    <tr>

                        <td>@item.Id</td>

                        <td>@item.Question</td>

                        <td>@item.OrderSort</td>

                        <td>

                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">
                                    فعال
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    غیرفعال
                                </span>
                            }

                        </td>

                        <td>

                            <button type="button"
                                    class="btn btn-warning btnEdit"
                                    data-id="@item.Id"
                                    data-question="@item.Question"
                                    data-answer="@item.Answer"
                                    data-ordersort="@item.OrderSort"
                                    data-isactive="@item.IsActive.ToString().ToLower()">
                                ویرایش
                            </button>

                            <form method="post"
                                  asp-page-handler="Delete"
                                  class="d-inline">

                                <input type="hidden"
                                       name="id"
                                       value="@item.Id" />

                                <button class="btn btn-danger btn-sm btnDelete">

                                    حذف

                                </button>

                            </form>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>


<partial name="_CreateOrEditService"
         model="Model.CreateModel"
         view-data='new ViewDataDictionary(ViewData)
         {
             ["ModalId"]="createModal",
             ["Title"]="افزودن سوال",
             ["Handler"]="Create"
         }' />

<partial name="_CreateOrEditService"
         model="Model.UpdateModel"
         view-data='new ViewDataDictionary(ViewData)
         {
             ["ModalId"]="editModal",
             ["Title"]="ویرایش سوال",
             ["Handler"]="Edit"
         }' />

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        document.querySelectorAll(".btnEdit").forEach(btn => {

            btn.onclick = function () {

                document.getElementById("UpdateModel_Id").value = this.dataset.id;

                document.getElementById("UpdateModel_Question").value = this.dataset.question;

                document.getElementById("UpdateModel_Answer").value = this.dataset.answer;

                document.getElementById("UpdateModel_OrderSort").value = this.dataset.ordersort;

                document.getElementById("UpdateModel_IsActive").checked = this.dataset.isactive === "true";

                new bootstrap.Modal(document.getElementById("editModal")).show();

            }

        });


        document.querySelectorAll(".btnEdit").forEach(btn => {

            btn.addEventListener("click", function () {

                console.log("clicked");

                new bootstrap.Modal(document.getElementById("editModal")).show();

            });

        });
        document.querySelectorAll(".btnDelete").forEach(btn => {

            btn.onclick = function (e) {

                if (!confirm("آیا از حذف مطمئن هستید؟")) {

                    e.preventDefault();

                }

            }

        });

    </script>

}