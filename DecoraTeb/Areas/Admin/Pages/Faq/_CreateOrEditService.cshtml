@model DecoraTeb.ViewModels.Faq.FaqFormVm

@{
    var modalId = ViewData["ModalId"]?.ToString() ?? "faqModal";
    var title = ViewData["Title"]?.ToString() ?? "";
    var handler = ViewData["Handler"]?.ToString() ?? "";
}

<div class="modal fade"
     id="@modalId"
     tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <form method="post"
                  asp-page-handler="@handler">

                <div class="modal-header">

                    <h5 class="modal-title">

                        @title

                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <div class="modal-body">

                    <input asp-for="Id" type="hidden" />

                    <div class="mb-3">

                        <label asp-for="Question"></label>

                        <input asp-for="Question"
                               class="form-control" />

                        <span asp-validation-for="Question"
                              class="text-danger"></span>

                    </div>

                    <div class="mb-3">

                        <label asp-for="Answer"></label>

                        <textarea asp-for="Answer"
                                  rows="5"
                                  class="form-control"></textarea>

                        <span asp-validation-for="Answer"
                              class="text-danger"></span>

                    </div>

                    <div class="row">

                        <div class="col-md-6">

                            <label asp-for="OrderSort"></label>

                            <input asp-for="OrderSort"
                                   class="form-control" />

                        </div>

                        <div class="col-md-6 d-flex align-items-center">

                            <div class="form-check mt-4">

                                <input asp-for="IsActive"
                                       class="form-check-input" />

                                <label asp-for="IsActive"
                                       class="form-check-label"></label>

                            </div>

                        </div>

                    </div>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-success">

                        ذخیره

                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">

                        انصراف

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>