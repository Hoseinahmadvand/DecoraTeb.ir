@page
@using DecoraTeb.Extensions
@model DecoraTeb.Areas.Admin.Pages.IndexModel
@{
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>داشبورد</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-left">
                    <li class="breadcrumb-item"><a href="#">خانه</a></li>
                  
                </ol>
            </div>
        </div>
    </div>
    <div class="row">

        <div class="col-lg-3">

            <div class="small-box bg-info">

                <div class="inner">

                    <h3>@Model.Dashboard.ProjectCount</h3>

                    <p>پروژه ها</p>

                </div>

                <div class="icon">

                    <i class="fa fa-building"></i>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="small-box bg-success">

                <div class="inner">

                    <h3>@Model.Dashboard.BlogCount</h3>

                    <p>مقالات</p>

                </div>

                <div class="icon">

                    <i class="fa fa-newspaper-o"></i>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="small-box bg-warning">

                <div class="inner">

                    <h3>@Model.Dashboard.ServiceCount</h3>

                    <p>خدمات</p>

                </div>

                <div class="icon">

                    <i class="fa fa-cogs"></i>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="small-box bg-danger">

                <div class="inner">

                    <h3>@Model.Dashboard.MessageCount</h3>

                    <p>پیام ها</p>

                </div>

                <div class="icon">

                    <i class="fa fa-envelope"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="card">

        <div class="card-header">

            <h3 class="card-title">

                آخرین پروژه ها

            </h3>

        </div>

        <div class="card-body table-responsive p-0">

            <table class="table table-hover">

                <thead>

                    <tr>

                        <th>عنوان</th>

                        <th>وضعیت</th>

                        <th>تاریخ</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.Dashboard.LatestProjects)
                    {
                        <tr>

                            <td>@item.Title</td>

                            <td>

                                @if (item.IsActive)
                                {
                                    <span class="badge badge-success">فعال</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">غیرفعال</span>
                                }

                            </td>

                            <td>@item.CreateDate.ToShamsi()</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
</section>